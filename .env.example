# ── Adresses ─────────────────────────────────────────────────────
PORT_BACKEND=8089
BACKEND_URL=http://localhost:8089
PORT_FRONTEND=4207
FRONTEND_URL=http://localhost:4207

# ── Base de données ──────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devdb
DB_SCHEMA=traitement_de_fichiers_compils
DB_USER=devuser
DB_PASSWORD=CHANGE_ME

# ── Django ───────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME
DEBUG=False
ALLOWED_HOSTS=*

# ── Reverse proxy (Caddy) ────────────────────────────────────────
SCRIPT_NAME=/traitement-de-fichiers-compils-api

# ── SSO Keycloak ─────────────────────────────────────────────────
KEYCLOAK_CLIENT_ID=traitement-de-fichiers-compils
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ssolab
# Client public (SPA Angular) — Keycloak → Clients → traitement-de-fichiers-compils → Access type : Public
# Valid redirect URIs : http://localhost:4207/*

# ── URLs (propagées automatiquement par reset_url.sh) ────────────
PORT_KEYCLOAK=8080
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN
KEYCLOAK_URL=http://192.168.1.X:8080
KEYCLOAK_PUBLIC_URL=http://VOTRE_IP_WAN:8080

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
DOMAIN=CHANGE_ME
